#!/usr/bin/env bash

PASSWORD_STORE_DIR="${PASSWORD_STORE_DIR:-$HOME/.password-store}"
clip_cmd="wl-copy"
type_cmd="wtype"

# --- Выбор записи ---
entry=$(find "$PASSWORD_STORE_DIR" -name '*.gpg' \
  | sed "s|$PASSWORD_STORE_DIR/||; s|.gpg$||" \
  | rofi -dmenu -p "pass:" -i)

[ -z "$entry" ] && exit

# --- Извлекаем данные ---
pass_data=$(pass show "$entry")
password=$(echo "$pass_data" | head -n1)
user=$(echo "$pass_data" | grep -i '^user:' | awk '{print $2}')

# --- Выбор действия ---
choice=$(echo -e "Copy password\nCopy username\nAutotype user+pass\nType only password\nType only username" \
  | rofi -dmenu -p "Action:" -i)

case "$choice" in
  "Copy password")
    echo -n "$password" | $clip_cmd
    notify-send "🔑 Password copied for $entry"
    ;;
  "Copy username")
    echo -n "$user" | $clip_cmd
    notify-send "👤 Username copied for $entry"
    ;;
  "Autotype user+pass")
    sleep 0.5
    $type_cmd "$user"
    $type_cmd -k tab
    $type_cmd "$password"
    $type_cmd -k enter
    ;;
  "Type only password")
    sleep 0.5
    $type_cmd "$password"
    ;;
  "Type only username")
    sleep 0.5
    $type_cmd "$user"
    ;;
esac

