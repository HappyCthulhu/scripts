#!/bin/bash
set -euo pipefail

# ---------------- CONFIG ----------------

AIRPODS_MAC="44:F0:9E:32:5F:F7"
AIRPODS_MAC_RE="44[_:]F0[_:]9E[_:]32[_:]5F[_:]F7"

FAMILY_SINK="alsa_output.pci-0000_04_00.6.HiFi__Speaker__sink"

MAX_ITER=100          # 100 × 50ms = 5s max (реально < 0.3s)
SLEEP_STEP=0.05       # 50 ms

# ---------------- LOGGING ----------------

log() {
    echo "[airpods] $*" >&2
}

# ---------------- BLUETOOTH ----------------

is_connected() {
    bluetoothctl info "$AIRPODS_MAC" 2>/dev/null | grep -q "Connected: yes"
}

# ---------------- SINK DETECTION ----------------

get_final_sink() {
    pactl list short sinks \
        | awk '{print $2}' \
        | grep -E "bluez_output.*$AIRPODS_MAC_RE" \
        | head -n 1 || true
}

# ---------------- FAST WAIT ----------------

wait_for_final_sink_fast() {
    for ((i=0; i<MAX_ITER; i++)); do
        final="$(get_final_sink)"
        if [[ -n "$final" ]]; then
            log "Final sink detected: $final"
            printf '%s\n' "$final"
            return 0
        fi
        sleep "$SLEEP_STEP"
    done
    return 1
}

# ---------------- AUDIO CONTROL ----------------

set_default_sink() {
    local sink="$1"

    log "Setting default sink: $sink"
    pactl set-default-sink "$sink"

    pactl list short sink-inputs | awk '{print $1}' | while read -r input; do
        pactl move-sink-input "$input" "$sink" || true
    done
}

ensure_default_sink() {
    local sink="$1"

    set_default_sink "$sink"
    sleep 0.2

    if ! pactl info | grep -q "Default Sink: $sink"; then
        log "Policy override detected, fixing default sink"
        set_default_sink "$sink"
    fi
}

# ---------------- MAIN ----------------

if is_connected; then
    log "Disconnecting AirPods"
    bluetoothctl disconnect "$AIRPODS_MAC" >/dev/null || true
    sleep 0.5
    set_default_sink "$FAMILY_SINK"
    exit 0
fi

log "Connecting AirPods"
if ! bluetoothctl connect "$AIRPODS_MAC" >/dev/null; then
    log "Bluetooth connect failed, fallback to family sink"
    set_default_sink "$FAMILY_SINK"
    exit 1
fi

log "Waiting for final AirPods sink (fast)"
AIRPODS_SINK="$(wait_for_final_sink_fast)" || {
    log "Final sink not detected, fallback"
    set_default_sink "$FAMILY_SINK"
    exit 1
}

ensure_default_sink "$AIRPODS_SINK"

log "Done"
